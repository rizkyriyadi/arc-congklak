{
  "name": "arc-game",
  "version": "0.0.1",
  "private": true,
  "description": "Arc Entertainment — foundation for browser-playable Indonesian indie games (TypeScript + HTML5 Canvas).",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:rules && npm run test:match",
    "test:rules": "esbuild src/congklak/rules.test.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/rules.test.mjs && node node_modules/.cache/rules.test.mjs",
    "test:match": "esbuild src/congklak/match.test.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/match.test.mjs && node node_modules/.cache/match.test.mjs",
    "build:standalone": "node scripts/build-standalone.mjs"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "esbuild": "^0.21.5"
  }
}
